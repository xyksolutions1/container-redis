#!/command/with-contenv bash

source /assets/functions/00-container
prepare_service
process_name="redis"

mkdir -p "${LOG_PATH}"
touch "${LOG_PATH}"/"${LOG_FILE}"
chown -R redis:redis "${LOG_PATH}"/"${LOG_FILE}"
create_logrotate redis "${LOG_PATH}"/"${LOG_FILE}" redis redis redis

if var_true "${ENABLE_SOCKET}" ; then
    mkdir -p "${SOCKET_PATH}"
    chown -R redis:redis "${SOCKET_PATH}"
    chmod "${SOCKET_PERMISSIONS}" "${SOCKET_PATH}"
fi

if var_true "${CONTAINER_ENABLE_MONITORING}" && [ "${CONTAINER_MONITORING_BACKEND,,}" = "zabbix" ]; then
    source /assets/defaults/03-monitoring
    cat <<EOF > "${ZABBIX_CONFIG_PATH}"/"${ZABBIX_CONFIG_FILE}.d"/tiredofit_redis.conf
# Zabbix Redis Configuration - Automatically Generated
# Autoregister=redis
EOF

    case "${ZABBIX_AGENT_TYPE,,}" in
        "1" | "classic" | "c" | "legacy" | "old" )
        :
    ;;
        "2" | "m" | "n" | "modern" | "new" )
            echo "Plugins.Redis.Sessions.${ZABBIX_SESSION_NAME}.Uri=tcp://localhost:${REDIS_PORT}" >> "${ZABBIX_CONFIG_PATH}"/"${ZABBIX_CONFIG_FILE}.d"/tiredofit_redis.conf
            if [ -n "${REDIS_PASS}" ] ; then
                echo "Plugins.Redis.Sessions.${ZABBIX_SESSION_NAME}.Password=${REDIS_PASS}" >> "${ZABBIX_CONFIG_PATH}"/"${ZABBIX_CONFIG_FILE}.d"/tiredofit_redis.conf
            fi
    ;;
    esac
fi


mkdir -p "${DATA_PATH}"
chown -R redis:redis "${DATA_PATH}"

liftoff